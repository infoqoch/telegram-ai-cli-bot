# ============================================================
# Required — bot will not start without these
# ============================================================

TELEGRAM_TOKEN=              # BotFather → /newbot → copy token
ALLOWED_CHAT_IDS=            # Your chat ID (send /chatid to bot). Comma-separated for multiple.
ADMIN_CHAT_ID=               # Same as above for single-user setup

# ============================================================
# Authentication
# ============================================================

REQUIRE_AUTH=false            # Set to true to enable auth
AUTH_SECRET_KEY=              # Required when REQUIRE_AUTH=true. Any random string.
AUTH_TIMEOUT_MINUTES=30

# ============================================================
# AI Provider
# ============================================================

AI_COMMAND=claude             # CLI binary name. Permission flags are added automatically by the bot.
# DEFAULT_MODEL_CLAUDE=       # Override default Claude model profile
# DEFAULT_MODEL_CODEX=        # Override default Codex model profile

# ============================================================
# General
# ============================================================

APP_TIMEZONE=Asia/Seoul       # Timezone for schedules and date display
SESSION_TIMEOUT_HOURS=24      # Hours before idle session is recycled
SESSION_PURGE_DAYS=7          # Days before recycled session is deleted
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR

# ============================================================
# Optional — uncomment and configure as needed
# ============================================================

# Workspace
# WORKING_DIR=                          # Bot working directory (defaults to project root)
# ALLOWED_PROJECT_PATHS=~/Projects/*    # Allowed workspace paths (glob, comma-separated)

# Google Calendar plugin
# GOOGLE_SERVICE_ACCOUNT_FILE=          # Path to service account JSON
# GOOGLE_CALENDAR_ID=primary            # Calendar ID (e.g., user@gmail.com)

# Advanced
# BOT_DATA_DIR=.data/                   # Runtime data directory
# BOT_LOG_DIR=.data/logs/               # Log directory
# BOT_MAIN_MENU_PLUGINS=               # Comma-separated plugin names for main menu
